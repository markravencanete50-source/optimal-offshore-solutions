# ─────────────────────────────────────────────────────────────
# Optimal Offshore Solutions — environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (Resend) — sends form leads to your inbox + auto-reply to the sender ──
# Get an API key at https://resend.com (API Keys). To send FROM your domain,
# verify optimaloffshoresolutions.com in Resend (adds DNS records in Namecheap).
RESEND_API_KEY=
MAIL_FROM="Optimal Offshore Solutions <hello@optimaloffshoresolutions.com>"
LEAD_NOTIFY_TO=sales@optimaloffshoresolutions.com

# ── Admin dashboard (/admin) ──
# Admins now sign in with a Firebase Authentication EMAIL + PASSWORD.
# Set it up once in the Firebase Console:
#   1. Authentication → Sign-in method → enable "Email/Password".
#   2. Authentication → Users → "Add user" → enter the admin's email + password.
#      (Repeat "Add user" for each person who should have access.)
# There is no self-signup on the site — only users you add here can sign in.
#
# Secret used to sign the admin session cookie. Use any long random string
# (e.g. `openssl rand -hex 32`). REQUIRED for the /admin login to work.
ADMIN_SESSION_SECRET=
# Optional: restrict /admin to specific accounts (comma-separated emails).
# Leave blank to allow any user you've added in the Firebase console.
ADMIN_EMAILS=

# ── Firebase Admin SDK (SERVER-SIDE — required for /admin; also used by /api/contact) ──
# From Firebase Console → Project Settings → Service accounts → Generate new private key.
# Paste the values from that JSON file below.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the quotes. Replace real newlines with \n, or paste the multi-line key as-is.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Firebase Web config (CLIENT-SIDE — optional, for future client reads) ──
# From Firebase Console → Project Settings → General → Your apps → Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
