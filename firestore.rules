rules_version = '2';

// Leads are written server-side by the Admin SDK (which bypasses these rules).
// This ruleset locks the database down for all client access by default.
// Loosen specific collections later if you add public client-side reads
// (e.g. published case studies).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
