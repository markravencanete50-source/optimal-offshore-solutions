rules_version = '2';

// Contact leads are created from the website (client SDK) with size-bounded,
// typed fields. Nobody can read, update, or delete them from the client — only
// your Firebase console / Admin SDK can. Everything else is locked down.
service cloud.firestore {
  match /databases/{database}/documents {

    match /leads/{doc} {
      allow create: if
        request.resource.data.firstName is string
        && request.resource.data.firstName.size() > 0
        && request.resource.data.firstName.size() < 100
        && request.resource.data.email is string
        && request.resource.data.email.size() < 200
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+[.][^@\\s]+$')
        && request.resource.data.company is string
        && request.resource.data.company.size() < 200
        && request.resource.data.industry is string
        && request.resource.data.industry.size() < 100
        && request.resource.data.challenge is string
        && request.resource.data.challenge.size() < 5000;
      allow read, update, delete: if false;
    }

    // Anonymous analytics beacons (pageviews / CTA clicks) written via the
    // website's /api/track route. Create-only, size-bounded; reads happen
    // exclusively through the Admin SDK on the /admin dashboard.
    match /events/{doc} {
      allow create: if
        request.resource.data.type is string
        && request.resource.data.type.size() < 40
        && request.resource.data.path is string
        && request.resource.data.path.size() < 300
        && request.resource.data.label is string
        && request.resource.data.label.size() < 100
        && request.resource.data.ref is string
        && request.resource.data.ref.size() < 500
        && request.resource.data.sid is string
        && request.resource.data.sid.size() < 100
        && request.resource.data.device is string
        && request.resource.data.device.size() < 20
        && request.resource.data.country is string
        && request.resource.data.country.size() < 10;
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
